# --- Server ---
NODE_ENV=production
# Port d'écoute local. 5678 par défaut pour éviter les conflits avec les autres
# apps de ton VPS (nginx fait le reverse proxy depuis le domaine vers ce port).
PORT=5678

# --- Sessions ---
# Génère une clé forte : `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET=change_me_to_a_long_random_string_min_32_chars

# --- Admin par défaut (utilisé uniquement au seed initial) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password_immediately

# --- Sécurité cookies (true en HTTPS prod, false en local) ---
COOKIE_SECURE=true

# --- URL publique (utilisée pour les balises canoniques / OG) ---
PUBLIC_URL=https://lemulsion-villeneuve.fr
