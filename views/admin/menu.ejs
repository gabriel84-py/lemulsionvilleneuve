<header class="admin-page-header">
  <div>
    <h1 class="admin-h1">Carte & menu</h1>
    <p class="admin-lede">Gérez vos catégories et tous vos plats.</p>
  </div>
  <a href="/admin/menu/items/new" class="admin-btn admin-btn-primary">＋ Nouveau plat</a>
</header>

<% if (flash) { %><div class="admin-flash"><%= flash %></div><% } %>

<!-- CATÉGORIES -->
<section class="admin-section">
  <h2 class="admin-h2">Catégories</h2>

  <details class="admin-details">
    <summary>＋ Ajouter une catégorie</summary>
    <form action="/admin/menu/categories" method="post" class="admin-form admin-form-inline">
      <%- include('../partials/_csrf') %>
      <div class="admin-grid-2">
        <label class="admin-field">
          <span>Slug (technique, sans espace)</span>
          <input type="text" name="slug" required pattern="[a-z0-9-]+" placeholder="smash-burgers" />
        </label>
        <label class="admin-field">
          <span>Ordre d'affichage</span>
          <input type="number" name="display_order" value="0" />
        </label>
      </div>

      <div class="admin-grid-3">
        <label class="admin-field"><span>Nom (FR)</span><input type="text" name="name_fr" required /></label>
        <label class="admin-field"><span>Name (EN)</span><input type="text" name="name_en" /></label>
        <label class="admin-field"><span>Nome (IT)</span><input type="text" name="name_it" /></label>
      </div>

      <div class="admin-grid-3">
        <label class="admin-field"><span>Description (FR)</span><input type="text" name="description_fr" /></label>
        <label class="admin-field"><span>Description (EN)</span><input type="text" name="description_en" /></label>
        <label class="admin-field"><span>Descrizione (IT)</span><input type="text" name="description_it" /></label>
      </div>

      <button type="submit" class="admin-btn admin-btn-primary">Créer la catégorie</button>
    </form>
  </details>

  <% categories.forEach(function(cat) { %>
    <details class="admin-details admin-cat-block">
      <summary>
        <strong><%= cat.name_fr %></strong>
        <span class="admin-cat-count"><%= itemsByCategory[cat.id]?.length || 0 %> plat<%= (itemsByCategory[cat.id]?.length || 0) > 1 ? 's' : '' %></span>
        <% if (!cat.is_visible) { %><span class="admin-tag admin-tag-warn">masqué</span><% } %>
      </summary>

      <form action="/admin/menu/categories/<%= cat.id %>" method="post" class="admin-form admin-form-inline">
        <%- include('../partials/_csrf') %>
        <div class="admin-grid-2">
          <label class="admin-field"><span>Slug</span><input type="text" name="slug" value="<%= cat.slug %>" required pattern="[a-z0-9-]+" /></label>
          <label class="admin-field"><span>Ordre</span><input type="number" name="display_order" value="<%= cat.display_order %>" /></label>
        </div>
        <div class="admin-grid-3">
          <label class="admin-field"><span>FR</span><input type="text" name="name_fr" value="<%= cat.name_fr %>" required /></label>
          <label class="admin-field"><span>EN</span><input type="text" name="name_en" value="<%= cat.name_en || '' %>" /></label>
          <label class="admin-field"><span>IT</span><input type="text" name="name_it" value="<%= cat.name_it || '' %>" /></label>
        </div>
        <div class="admin-grid-3">
          <label class="admin-field"><span>Desc FR</span><input type="text" name="description_fr" value="<%= cat.description_fr || '' %>" /></label>
          <label class="admin-field"><span>Desc EN</span><input type="text" name="description_en" value="<%= cat.description_en || '' %>" /></label>
          <label class="admin-field"><span>Desc IT</span><input type="text" name="description_it" value="<%= cat.description_it || '' %>" /></label>
        </div>
        <label class="admin-field admin-checkbox">
          <input type="checkbox" name="is_visible" <%= cat.is_visible ? 'checked' : '' %> />
          <span>Visible sur le site</span>
        </label>
        <div class="admin-form-actions">
          <button type="submit" class="admin-btn admin-btn-primary">Enregistrer</button>
        </div>
      </form>

      <!-- Items dans cette catégorie -->
      <% if (itemsByCategory[cat.id] && itemsByCategory[cat.id].length) { %>
        <div class="admin-items-list">
          <% itemsByCategory[cat.id].forEach(function(item) { %>
            <div class="admin-item-row">
              <% if (item.image_path) { %>
                <img src="<%= item.image_path %>" alt="" class="admin-item-thumb" />
              <% } else { %>
                <div class="admin-item-thumb admin-item-thumb-empty">◇</div>
              <% } %>
              <div class="admin-item-info">
                <strong><%= item.name_fr %></strong>
                <span class="admin-item-price"><%= item.price %></span>
                <% if (item.is_veggie) { %><span class="admin-tag admin-tag-veggie">🌱 Végé</span><% } %>
                <% if (item.is_featured) { %><span class="admin-tag admin-tag-featured">★ Mis en avant</span><% } %>
                <% if (!item.is_visible) { %><span class="admin-tag admin-tag-warn">masqué</span><% } %>
              </div>
              <div class="admin-item-actions">
                <a href="/admin/menu/items/<%= item.id %>/edit" class="admin-btn admin-btn-ghost admin-btn-sm">Modifier</a>
                <form action="/admin/menu/items/<%= item.id %>/delete" method="post" onsubmit="return confirm('Supprimer ce plat ?')" style="display:inline">
                  <%- include('../partials/_csrf') %>
                  <button type="submit" class="admin-btn admin-btn-danger admin-btn-sm">Supprimer</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="admin-empty">Aucun plat dans cette catégorie.</p>
      <% } %>

      <form action="/admin/menu/categories/<%= cat.id %>/delete" method="post" onsubmit="return confirm('Supprimer la catégorie ET tous ses plats ?')" class="admin-cat-delete">
        <%- include('../partials/_csrf') %>
        <button type="submit" class="admin-btn admin-btn-danger admin-btn-sm">Supprimer la catégorie</button>
      </form>
    </details>
  <% }) %>
</section>
