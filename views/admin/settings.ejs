<header class="admin-page-header">
  <h1 class="admin-h1">Contenu général</h1>
  <p class="admin-lede">Hero, à propos, infos de contact, réservation, réseaux sociaux et bandeau d'annonce.</p>
</header>

<% if (flash) { %>
  <div class="admin-flash"><%= flash %></div>
<% } %>

<form action="/admin/settings" method="post" enctype="multipart/form-data" class="admin-form">
  <%- include('../partials/_csrf') %>

  <!-- HERO -->
  <fieldset class="admin-fieldset">
    <legend>Hero (page d'accueil)</legend>

    <div class="admin-i18n-tabs" data-i18n-group="hero_title">
      <div class="admin-i18n-tablist">
        <button type="button" class="admin-i18n-tab is-active" data-lang="fr">FR</button>
        <button type="button" class="admin-i18n-tab" data-lang="en">EN</button>
        <button type="button" class="admin-i18n-tab" data-lang="it">IT</button>
      </div>
      <label class="admin-field admin-i18n-panel is-active" data-lang="fr">
        <span>Titre principal (FR)</span>
        <input type="text" name="hero_title_fr" value="<%= settings.hero_title?.fr || '' %>" placeholder="Ex : Bistronomie sous les arcades" />
      </label>
      <label class="admin-field admin-i18n-panel" data-lang="en">
        <span>Main title (EN)</span>
        <input type="text" name="hero_title_en" value="<%= settings.hero_title?.en || '' %>" />
      </label>
      <label class="admin-field admin-i18n-panel" data-lang="it">
        <span>Titolo principale (IT)</span>
        <input type="text" name="hero_title_it" value="<%= settings.hero_title?.it || '' %>" />
      </label>
    </div>

    <div class="admin-i18n-tabs" data-i18n-group="hero_subtitle">
      <div class="admin-i18n-tablist">
        <button type="button" class="admin-i18n-tab is-active" data-lang="fr">FR</button>
        <button type="button" class="admin-i18n-tab" data-lang="en">EN</button>
        <button type="button" class="admin-i18n-tab" data-lang="it">IT</button>
      </div>
      <label class="admin-field admin-i18n-panel is-active" data-lang="fr">
        <span>Sous-titre (FR)</span>
        <textarea name="hero_subtitle_fr" rows="3"><%= settings.hero_subtitle?.fr || '' %></textarea>
      </label>
      <label class="admin-field admin-i18n-panel" data-lang="en">
        <span>Subtitle (EN)</span>
        <textarea name="hero_subtitle_en" rows="3"><%= settings.hero_subtitle?.en || '' %></textarea>
      </label>
      <label class="admin-field admin-i18n-panel" data-lang="it">
        <span>Sottotitolo (IT)</span>
        <textarea name="hero_subtitle_it" rows="3"><%= settings.hero_subtitle?.it || '' %></textarea>
      </label>
    </div>

    <label class="admin-field">
      <span>Image principale du hero</span>
      <% if (settings.hero_image) { %>
        <div class="admin-image-preview">
          <img src="<%= settings.hero_image %>" alt="" />
        </div>
      <% } %>
      <input type="file" name="hero_image" accept="image/*" />
      <small>JPG, PNG ou WebP — max 8 MB. L'image sera redimensionnée et convertie en WebP automatiquement.</small>
    </label>
  </fieldset>

  <!-- À PROPOS -->
  <fieldset class="admin-fieldset">
    <legend>Section « À propos »</legend>

    <div class="admin-i18n-tabs">
      <div class="admin-i18n-tablist">
        <button type="button" class="admin-i18n-tab is-active" data-lang="fr">FR</button>
        <button type="button" class="admin-i18n-tab" data-lang="en">EN</button>
        <button type="button" class="admin-i18n-tab" data-lang="it">IT</button>
      </div>
      <label class="admin-field admin-i18n-panel is-active" data-lang="fr">
        <span>Titre (FR)</span>
        <input type="text" name="about_title_fr" value="<%= settings.about_title?.fr || '' %>" />
      </label>
      <label class="admin-field admin-i18n-panel" data-lang="en">
        <span>Title (EN)</span>
        <input type="text" name="about_title_en" value="<%= settings.about_title?.en || '' %>" />
      </label>
      <label class="admin-field admin-i18n-panel" data-lang="it">
        <span>Titolo (IT)</span>
        <input type="text" name="about_title_it" value="<%= settings.about_title?.it || '' %>" />
      </label>
    </div>

    <div class="admin-i18n-tabs">
      <div class="admin-i18n-tablist">
        <button type="button" class="admin-i18n-tab is-active" data-lang="fr">FR</button>
        <button type="button" class="admin-i18n-tab" data-lang="en">EN</button>
        <button type="button" class="admin-i18n-tab" data-lang="it">IT</button>
      </div>
      <label class="admin-field admin-i18n-panel is-active" data-lang="fr">
        <span>Texte (FR)</span>
        <textarea name="about_text_fr" rows="8"><%= settings.about_text?.fr || '' %></textarea>
        <small>Sautez une ligne pour créer un nouveau paragraphe.</small>
      </label>
      <label class="admin-field admin-i18n-panel" data-lang="en">
        <span>Text (EN)</span>
        <textarea name="about_text_en" rows="8"><%= settings.about_text?.en || '' %></textarea>
      </label>
      <label class="admin-field admin-i18n-panel" data-lang="it">
        <span>Testo (IT)</span>
        <textarea name="about_text_it" rows="8"><%= settings.about_text?.it || '' %></textarea>
      </label>
    </div>

    <label class="admin-field">
      <span>Image de la section « À propos »</span>
      <% if (settings.about_image) { %>
        <div class="admin-image-preview">
          <img src="<%= settings.about_image %>" alt="" />
        </div>
      <% } %>
      <input type="file" name="about_image" accept="image/*" />
    </label>
  </fieldset>

  <!-- BANDEAU D'ANNONCE -->
  <fieldset class="admin-fieldset">
    <legend>Bandeau d'annonce (en haut du site)</legend>

    <label class="admin-field admin-checkbox">
      <input type="checkbox" name="announcement_active" value="1" <%= settings.announcement_active === '1' || settings.announcement_active === 1 ? 'checked' : '' %> />
      <span>Activer le bandeau</span>
    </label>

    <div class="admin-i18n-tabs">
      <div class="admin-i18n-tablist">
        <button type="button" class="admin-i18n-tab is-active" data-lang="fr">FR</button>
        <button type="button" class="admin-i18n-tab" data-lang="en">EN</button>
        <button type="button" class="admin-i18n-tab" data-lang="it">IT</button>
      </div>
      <label class="admin-field admin-i18n-panel is-active" data-lang="fr">
        <span>Texte (FR)</span>
        <input type="text" name="announcement_text_fr" value="<%= settings.announcement_text?.fr || '' %>" placeholder="Ex : Fermé exceptionnellement le 14 juillet" />
      </label>
      <label class="admin-field admin-i18n-panel" data-lang="en">
        <span>Text (EN)</span>
        <input type="text" name="announcement_text_en" value="<%= settings.announcement_text?.en || '' %>" />
      </label>
      <label class="admin-field admin-i18n-panel" data-lang="it">
        <span>Testo (IT)</span>
        <input type="text" name="announcement_text_it" value="<%= settings.announcement_text?.it || '' %>" />
      </label>
    </div>
  </fieldset>

  <!-- CONTACT -->
  <fieldset class="admin-fieldset">
    <legend>Coordonnées</legend>
    <label class="admin-field">
      <span>Nom du restaurant</span>
      <input type="text" name="restaurant_name" value="<%= settings.restaurant_name || '' %>" required />
    </label>

    <div class="admin-grid-2">
      <label class="admin-field">
        <span>Téléphone</span>
        <input type="text" name="phone" value="<%= settings.phone || '' %>" placeholder="+33 4 90 02 05 39" />
      </label>
      <label class="admin-field">
        <span>Email</span>
        <input type="email" name="email" value="<%= settings.email || '' %>" />
      </label>
    </div>

    <label class="admin-field">
      <span>Adresse</span>
      <input type="text" name="address_street" value="<%= settings.address_street || '' %>" placeholder="1 rue de l'Hôpital" />
    </label>

    <div class="admin-grid-2">
      <label class="admin-field">
        <span>Code postal</span>
        <input type="text" name="address_postal" value="<%= settings.address_postal || '' %>" />
      </label>
      <label class="admin-field">
        <span>Ville</span>
        <input type="text" name="address_city" value="<%= settings.address_city || '' %>" />
      </label>
    </div>

    <div class="admin-grid-2">
      <label class="admin-field">
        <span>Latitude</span>
        <input type="text" name="geo_lat" value="<%= settings.geo_lat || '' %>" placeholder="43.9660" />
      </label>
      <label class="admin-field">
        <span>Longitude</span>
        <input type="text" name="geo_lng" value="<%= settings.geo_lng || '' %>" placeholder="4.7970" />
      </label>
    </div>
  </fieldset>

  <!-- RÉSEAUX SOCIAUX -->
  <fieldset class="admin-fieldset">
    <legend>Réseaux sociaux</legend>
    <label class="admin-field">
      <span>Instagram (URL)</span>
      <input type="url" name="social_instagram" value="<%= settings.social_instagram || '' %>" placeholder="https://www.instagram.com/lemulsionvilleneuve/" />
    </label>
    <label class="admin-field">
      <span>Facebook (URL)</span>
      <input type="url" name="social_facebook" value="<%= settings.social_facebook || '' %>" />
    </label>
    <label class="admin-field">
      <span>Google Maps (URL fiche / itinéraire)</span>
      <input type="url" name="social_google_maps" value="<%= settings.social_google_maps || '' %>" />
    </label>
  </fieldset>

  <!-- NOTE / SEO -->
  <fieldset class="admin-fieldset">
    <legend>Note publique &amp; SEO</legend>
    <div class="admin-grid-2">
      <label class="admin-field">
        <span>Note moyenne</span>
        <input type="text" name="rating_value" value="<%= settings.rating_value || '4.8' %>" />
      </label>
      <label class="admin-field">
        <span>Nombre d'avis</span>
        <input type="text" name="rating_count" value="<%= settings.rating_count || '126' %>" />
      </label>
    </div>
    <label class="admin-field">
      <span>Description SEO (meta description)</span>
      <textarea name="meta_description" rows="3" maxlength="320"><%= settings.meta_description || '' %></textarea>
      <small>Utilisée par Google et le partage sur les réseaux. 150–160 caractères idéal.</small>
    </label>
  </fieldset>

  <div class="admin-form-actions">
    <button type="submit" class="admin-btn admin-btn-primary">Enregistrer les modifications</button>
  </div>
</form>
