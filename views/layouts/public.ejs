<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#f4efe6" />

  <title><%= settings && settings.restaurant_name ? settings.restaurant_name : 'L\'Émulsion' %> · <%= tr(settings.hero_title) || t('hero.subtitle') %></title>

  <meta name="description" content="<%= settings && settings.meta_description ? settings.meta_description : 'L\'Émulsion, restaurant bistronomique à Villeneuve-lès-Avignon. Cuisine française et provençale, produits du marché, par le chef Damien Chocano.' %>" />

  <!-- Open Graph -->
  <meta property="og:title" content="<%= settings.restaurant_name || 'L\'Émulsion' %>" />
  <meta property="og:description" content="<%= tr(settings.hero_title) || t('hero.subtitle') %>" />
  <meta property="og:type" content="restaurant" />
  <meta property="og:image" content="<%= publicUrl %>/images/logo.jpg" />
  <meta property="og:locale" content="<%= lang === 'fr' ? 'fr_FR' : (lang === 'en' ? 'en_US' : 'it_IT') %>" />

  <!-- Fonts : Playfair Display (hero display), Cormorant Garamond (serif corps),
       Fraunces (italic accent), Inter (UI) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;0,900;1,400;1,500;1,700&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/public.css" />
  <link rel="icon" type="image/jpeg" href="/images/logo.jpg" />

  <!-- JSON-LD (Restaurant) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Restaurant",
    "name": "<%= settings.restaurant_name || 'L\'Émulsion' %>",
    "image": "<%= publicUrl %>/images/logo.jpg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "<%= settings.address_street || '' %>",
      "addressLocality": "<%= settings.address_city || '' %>",
      "postalCode": "<%= settings.address_postal || '' %>",
      "addressCountry": "FR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": <%= settings.geo_lat || 0 %>,
      "longitude": <%= settings.geo_lng || 0 %>
    },
    "telephone": "<%= settings.phone || '' %>",
    "email": "<%= settings.email || '' %>",
    "priceRange": "€€€",
    "servesCuisine": ["French", "Bistronomy", "Provençal"],
    "acceptsReservations": true,
    "hasMenu": "<%= publicUrl %>/menu"<% if (settings.phone) { %>,
    "potentialAction": {
      "@type": "ReserveAction",
      "target": "tel:<%= settings.phone.replace(/\s/g, '') %>"
    }<% } %>
  }
  </script>
</head>
<body data-page="<%= page %>">

  <%- include('../partials/announcement-bar') %>
  <%- include('../partials/header') %>
  <%- include('../partials/mobile-drawer') %>

  <main id="main">
    <%- body %>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/floating-order') %>

  <script src="/js/public.js" defer></script>
</body>
</html>
