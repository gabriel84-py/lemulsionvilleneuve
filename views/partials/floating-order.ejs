<%
  var phone = settings && settings.phone ? settings.phone : null;
  var phoneTel = phone ? phone.replace(/\s/g, '') : null;
  var maps = settings && settings.social_google_maps ? settings.social_google_maps : null;
  var hasAny = phoneTel || maps;
%>
<% if (hasAny) { %>
  <nav class="mobile-bottombar" data-mobile-bottombar aria-label="Actions rapides">
    <% if (maps) { %>
      <a href="<%= maps %>" target="_blank" rel="noopener" class="mobile-bottombar-btn" aria-label="<%= t('contact.directions') %>">
        <span class="mobile-bottombar-btn-icon" aria-hidden="true">◈</span>
        <span class="mobile-bottombar-btn-label"><%= t('contact.directions') %></span>
      </a>
    <% } %>
    <a href="/menu" class="mobile-bottombar-btn" aria-label="<%= t('nav.menu') %>">
      <span class="mobile-bottombar-btn-icon" aria-hidden="true">✦</span>
      <span class="mobile-bottombar-btn-label"><%= t('nav.menu') %></span>
    </a>
    <% if (phoneTel) { %>
      <a href="tel:<%= phoneTel %>" class="mobile-bottombar-btn is-primary" aria-label="<%= t('nav.reserve') %>">
        <span class="mobile-bottombar-btn-icon" aria-hidden="true">☏</span>
        <span class="mobile-bottombar-btn-label"><%= t('nav.reserve') %></span>
      </a>
    <% } %>
  </nav>
<% } %>
