<header class="site-header" data-header>
  <div class="site-header-inner">
    <a href="/" class="site-brand" aria-label="<%= settings.restaurant_name || 'L\'Émulsion' %> — Accueil">
      <img src="/images/logo.jpg" alt="" class="site-brand-mark" />
      <span class="site-brand-text">
        <strong><%= settings.restaurant_name || 'L\'Émulsion' %></strong>
        <em>Villeneuve-lès-Avignon</em>
      </span>
    </a>

    <nav class="site-nav" aria-label="Navigation principale">
      <a href="/" class="site-nav-link <%= page === 'home' ? 'is-active' : '' %>"><%= t('nav.home') %></a>
      <a href="/menu" class="site-nav-link <%= page === 'menu' ? 'is-active' : '' %>"><%= t('nav.menu') %></a>
      <a href="/galerie" class="site-nav-link <%= page === 'gallery' ? 'is-active' : '' %>"><%= t('nav.gallery') %></a>
      <a href="/avis" class="site-nav-link <%= page === 'reviews' ? 'is-active' : '' %>"><%= t('nav.reviews') %></a>
      <a href="/contact" class="site-nav-link <%= page === 'contact' ? 'is-active' : '' %>"><%= t('nav.contact') %></a>
    </nav>

    <div class="site-header-tools">
      <div class="lang-switcher" aria-label="Choisir la langue">
        <% SUPPORTED_LANGS.forEach(function(code) { %>
          <a href="/lang/<%= code %>" class="lang-switcher-link <%= lang === code ? 'is-active' : '' %>" aria-current="<%= lang === code ? 'true' : 'false' %>"><%= code.toUpperCase() %></a>
        <% }) %>
      </div>

      <% if (settings && settings.phone) { %>
        <a href="tel:<%= settings.phone.replace(/\s/g, '') %>" class="btn-reserve-header">
          <span class="btn-reserve-header-label"><%= t('nav.reserve') %></span>
          <span class="btn-reserve-header-phone"><%= settings.phone %></span>
        </a>
      <% } %>

      <button class="site-burger" aria-label="Menu" aria-expanded="false" aria-controls="site-drawer" data-burger>
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>
