<!-- ─── HERO ÉDITORIAL ─────────────────────────────────────────────────── -->
<section class="hero" data-hero>
  <div class="hero-artwork" aria-hidden="true">
    <% if (settings.hero_image) { %>
      <img src="<%= settings.hero_image %>" alt="" />
    <% } else { %>
      <img src="/images/hero-artwork.svg" alt="" />
    <% } %>
  </div>
  <div class="hero-veil" aria-hidden="true"></div>

  <span class="hero-corner-num" aria-hidden="true">I</span>

  <div class="hero-grid">
    <div class="hero-content">
      <div class="hero-status reveal-fade" style="--delay: 0.1s">
        <% if (status.isOpen) { %>
          <span class="status-dot is-open" aria-hidden="true"></span>
          <span><%= status.message %></span>
        <% } else { %>
          <span class="status-dot is-closed" aria-hidden="true"></span>
          <span><%= status.message %></span>
        <% } %>
      </div>

      <span class="hero-eyebrow reveal-fade" style="--delay: 0.15s">
        Bistronomie · Depuis 2019
      </span>

      <h1 class="hero-title reveal" style="--delay: 0.2s">
        <% var heroTitle = tr(settings.hero_title) || 'Bistronomie sous les arcades'; %>
        <%= heroTitle %>
      </h1>

      <span class="hero-title-rule reveal-rule" style="--delay: 0.55s" aria-hidden="true"></span>

      <p class="hero-subtitle reveal-fade" style="--delay: 0.4s">
        <% var heroSub = tr(settings.hero_subtitle) || t('hero.subtitle'); %>
        <%= heroSub %>
      </p>

      <div class="hero-actions reveal-fade" style="--delay: 0.55s">
        <% if (settings.phone) { %>
          <a href="tel:<%= settings.phone.replace(/\s/g, '') %>" class="btn-phone">
            <span class="btn-phone-label"><%= t('nav.reserve') %></span>
            <span class="btn-phone-number"><%= settings.phone %></span>
          </a>
        <% } %>
        <a href="/menu" class="btn btn-outline--gold btn-lg">
          <span><%= t('hero.cta_menu') %></span>
          <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
      </div>

      <div class="hero-rating reveal-fade" style="--delay: 0.7s">
        <div class="hero-rating-stars" aria-hidden="true">★ ★ ★ ★ ★</div>
        <p>
          <strong><%= settings.rating_value || '4.8' %>/5</strong>
          <span>· <%= settings.rating_count || '126' %> <%= lang === 'en' ? 'reviews on TripAdvisor & Google' : (lang === 'it' ? 'recensioni su TripAdvisor e Google' : 'avis sur TripAdvisor & Google') %></span>
        </p>
      </div>
    </div>
  </div>

  <span class="hero-scroll" aria-hidden="true">Faites défiler</span>
</section>

<!-- ─── MARQUEE ────────────────────────────────────────────────────────── -->
<div class="marquee" aria-hidden="true">
  <div class="marquee-track">
    <% for (var i = 0; i < 3; i++) { %>
      <span>Bistronomie</span><span class="marquee-dot">◆</span>
      <span>Produits du marché</span><span class="marquee-dot">◆</span>
      <span>Villeneuve-lès-Avignon</span><span class="marquee-dot">◆</span>
      <span>Carte du jour</span><span class="marquee-dot">◆</span>
      <span>Table gourmande</span><span class="marquee-dot">◆</span>
    <% } %>
  </div>
</div>

<!-- ─── ABOUT ──────────────────────────────────────────────────────────── -->
<section class="about" id="about">
  <div class="about-inner">
    <div class="about-content reveal">
      <span class="chapter-num">II. Chapitre</span>
      <span class="eyebrow"><%= t('about.subtitle') %></span>
      <h2 class="section-title">
        <% var aboutTitle = tr(settings.about_title) || t('about.title'); %>
        <%= aboutTitle %>
      </h2>
      <div class="about-text">
        <% var aboutText = tr(settings.about_text); %>
        <% if (aboutText) { %>
          <%- aboutText.split('\n').filter(function(p) { return p.trim(); }).map(function(p) { return '<p>' + p + '</p>'; }).join('') %>
        <% } %>
      </div>

      <div class="about-signature">
        <img src="/images/signature.svg" alt="Damien Chocano" />
        <div class="about-signature-meta">
          <strong>Damien Chocano</strong>
          <%= lang === 'en' ? 'Chef & founder' : (lang === 'it' ? 'Chef e fondatore' : 'Chef & fondateur') %>
        </div>
      </div>

      <div class="about-features">
        <div class="about-feature">
          <span><%= t('about.feature_1_text') %></span>
          <strong><%= t('about.feature_1_label') %></strong>
        </div>
        <div class="about-feature">
          <span><%= t('about.feature_2_text') %></span>
          <strong><%= t('about.feature_2_label') %></strong>
        </div>
        <div class="about-feature">
          <span><%= t('about.feature_3_text') %></span>
          <strong><%= t('about.feature_3_label') %></strong>
        </div>
        <div class="about-feature">
          <span><%= t('about.feature_4_text') %></span>
          <strong><%= t('about.feature_4_label') %></strong>
        </div>
      </div>
    </div>

    <div class="about-visual reveal">
      <% if (settings.about_image) { %>
        <img src="<%= settings.about_image %>" alt="" />
      <% } else if (featured && featured.length > 1 && featured[1].image_path) { %>
        <img src="<%= featured[1].image_path %>" alt="" />
      <% } else { %>
        <div class="about-visual-placeholder">
          <span class="about-visual-emoji">— la maison —</span>
        </div>
      <% } %>
    </div>
  </div>
</section>

<!-- ─── PULL QUOTE — atmosphérique ─────────────────────────────────────── -->
<section class="pull-quote">
  <div class="pull-quote-inner">
    <span class="pull-quote-mark" aria-hidden="true">"</span>
    <p class="pull-quote-text reveal">
      <%= lang === 'en'
        ? 'The kitchen, when it is just, holds to very little — a product, a gesture, a moment.'
        : (lang === 'it'
          ? 'La cucina, quando è giusta, tiene a poco — un prodotto, un gesto, un istante.'
          : 'La cuisine, quand elle est juste, tient à peu — un produit, un geste, un instant.') %>
    </p>
    <span class="pull-quote-attr">— Damien Chocano</span>
  </div>
</section>

<!-- ─── SIGNATURES DU CHEF (featured) ──────────────────────────────────── -->
<% if (featured && featured.length) { %>
<section class="featured">
  <div class="featured-header reveal">
    <span class="chapter-num">III. Chapitre</span>
    <span class="eyebrow eyebrow--ornate"><%= t('menu.featured') %></span>
    <h2 class="section-title"><em><%= t('featured.title') %></em></h2>
  </div>

  <div class="featured-grid">
    <% featured.slice(0, 3).forEach(function(item, idx) { %>
      <article class="featured-card reveal" style="--delay: <%= idx * 0.12 %>s">
        <span class="featured-card-num"><%= ['N° I', 'N° II', 'N° III'][idx] || ('N° ' + (idx+1)) %></span>
        <div class="featured-card-image">
          <% if (item.image_path) { %>
            <img src="<%= item.image_path %>" alt="<%= tr({ fr: item.name_fr, en: item.name_en, it: item.name_it }) %>" loading="lazy" />
          <% } else { %>
            <div class="featured-card-placeholder">✦</div>
          <% } %>
          <% if (item.is_veggie) { %>
            <span class="badge-veggie"><%= t('menu.veggie') %></span>
          <% } %>
        </div>
        <div class="featured-card-body">
          <h3 class="featured-card-title">
            <%= tr({ fr: item.name_fr, en: item.name_en, it: item.name_it }) %>
          </h3>
          <p class="featured-card-desc">
            <%= tr({ fr: item.description_fr, en: item.description_en, it: item.description_it }) %>
          </p>
          <div class="featured-card-footer">
            <span class="featured-card-price"><%= item.price %></span>
          </div>
        </div>
      </article>
    <% }) %>
  </div>

  <div class="featured-cta reveal">
    <a href="/menu" class="btn btn-outline btn-lg">
      <span><%= t('hero.cta_menu') %></span>
      <span class="btn-arrow" aria-hidden="true">→</span>
    </a>
  </div>
</section>
<% } %>

<!-- ─── ORNEMENT ─────────────────────────────────────────────────────────── -->
<div class="section-divider section-divider--paper">
  <div class="ornament" aria-hidden="true">
    <span class="ornament-diamond"></span>
  </div>
</div>

<!-- ─── GALERIE PREVIEW ────────────────────────────────────────────────── -->
<% if (gallery && gallery.length) { %>
<section class="gallery-preview">
  <div class="gallery-preview-header reveal">
    <span class="chapter-num">IV. Chapitre</span>
    <span class="eyebrow"><%= t('gallery.subtitle') %></span>
    <h2 class="section-title"><em><%= t('gallery.title') %></em></h2>
  </div>

  <div class="gallery-preview-grid">
    <% gallery.slice(0, 6).forEach(function(photo, idx) { %>
      <a href="/galerie" class="gallery-preview-item reveal" style="--delay: <%= idx * 0.06 %>s">
        <img src="<%= photo.image_path %>" alt="<%= tr({ fr: photo.caption_fr, en: photo.caption_en, it: photo.caption_it }) || '' %>" loading="lazy" />
      </a>
    <% }) %>
  </div>
</section>
<% } %>

<!-- ─── AVIS (preview) ─────────────────────────────────────────────────── -->
<% if (reviews && reviews.length) { %>
<section class="reviews-preview">
  <div class="reviews-preview-inner">
    <div class="reviews-preview-header reveal">
      <span class="chapter-num">V. Chapitre</span>
      <span class="eyebrow">★ ★ ★ ★ ★ &nbsp;·&nbsp; <%= settings.rating_value || '4.8' %>/5</span>
      <h2 class="section-title"><em><%= t('reviews.title') %></em></h2>
    </div>

    <div class="reviews-preview-grid">
      <% reviews.slice(0, 3).forEach(function(review, idx) { %>
        <article class="review-card reveal" style="--delay: <%= idx * 0.12 %>s">
          <div class="review-card-stars" aria-hidden="true">
            <% for (var i = 0; i < (review.rating || 5); i++) { %>★<% } %>
          </div>
          <p class="review-card-content">
            <%= tr({ fr: review.content_fr, en: review.content_en, it: review.content_it }) %>
          </p>
          <div class="review-card-footer">
            <strong><%= review.author %></strong>
            <% if (review.source) { %><span><%= review.source %></span><% } %>
          </div>
        </article>
      <% }) %>
    </div>

    <div class="reviews-preview-cta reveal">
      <a href="/avis" class="btn btn-outline--gold btn-lg">
        <span><%= t('reviews.see_all') %></span>
        <span class="btn-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
<% } %>

<!-- ─── CONTACT TEASER ─────────────────────────────────────────────────── -->
<section class="contact-teaser">
  <div class="contact-teaser-inner">
    <div class="contact-teaser-content reveal">
      <span class="chapter-num">VI. Chapitre</span>
      <span class="eyebrow"><%= t('contact.subtitle') %></span>
      <h2 class="section-title"><em><%= t('contact.title') %></em></h2>

      <% if (settings.phone) { %>
        <a href="tel:<%= settings.phone.replace(/\s/g, '') %>" class="contact-teaser-phone">
          <span class="contact-teaser-phone-label"><%= t('nav.reserve') %></span>
          <span class="contact-teaser-phone-number"><%= settings.phone %></span>
        </a>
      <% } %>

      <p class="contact-teaser-address">
        <%= settings.address_street || '1 rue de l\'Hôpital' %><br/>
        <%= settings.address_postal || '30400' %> <%= settings.address_city || 'Villeneuve-lès-Avignon' %>
      </p>

      <div class="contact-teaser-actions">
        <a href="/contact" class="btn btn-ghost">
          <%= t('nav.contact') %>
          <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <% if (settings.geo_lat && settings.geo_lng) { %>
    <div class="contact-teaser-map reveal">
      <iframe
        src="https://www.google.com/maps?q=<%= settings.geo_lat %>,<%= settings.geo_lng %>&hl=<%= lang %>&z=15&output=embed"
        loading="lazy"
        title="Carte du restaurant"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>
    <% } %>
  </div>
</section>
