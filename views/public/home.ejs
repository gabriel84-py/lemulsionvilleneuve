<!-- ─── HERO ──────────────────────────────────────────────────────────── -->
<section class="hero">
  <div class="hero-grid">
    <div class="hero-content reveal">
      <div class="hero-status">
        <% if (status.isOpen) { %>
          <span class="status-dot is-open" aria-hidden="true"></span>
          <span><%= status.message %></span>
        <% } else { %>
          <span class="status-dot is-closed" aria-hidden="true"></span>
          <span><%= status.message %></span>
        <% } %>
      </div>

      <h1 class="hero-title">
        <% var heroTitle = tr(settings.hero_title) || 'Smash burgers, tacos & spécialité provençale'; %>
        <%= heroTitle %>
      </h1>

      <p class="hero-subtitle">
        <% var heroSub = tr(settings.hero_subtitle) || t('hero.subtitle'); %>
        <%= heroSub %>
      </p>

      <div class="hero-actions">
        <a href="/menu" class="btn btn-primary">
          <span><%= t('hero.cta_menu') %></span>
          <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <% if (settings.social_ubereats) { %>
          <a href="<%= settings.social_ubereats %>" target="_blank" rel="noopener" class="btn btn-ghost">
            <%= t('hero.cta_order') %>
          </a>
        <% } %>
      </div>

      <div class="hero-rating">
        <div class="hero-rating-stars" aria-hidden="true">
          <% for (var i = 0; i < 5; i++) { %><span>★</span><% } %>
        </div>
        <p>
          <strong><%= settings.rating_value || '4.8' %>/5</strong> ·
          <%= settings.rating_count || '292' %> <%= lang === 'en' ? 'Google reviews' : (lang === 'it' ? 'recensioni Google' : 'avis Google') %>
        </p>
      </div>
    </div>

    <div class="hero-visual reveal">
      <div class="hero-visual-frame">
        <% if (settings.hero_image) { %>
          <img src="<%= settings.hero_image %>" alt="" class="hero-visual-image" />
        <% } else if (featured && featured.length && featured[0].image_path) { %>
          <img src="<%= featured[0].image_path %>" alt="" class="hero-visual-image" />
        <% } else { %>
          <div class="hero-visual-placeholder">
            <span>🍔</span>
            <em>Photo à venir</em>
          </div>
        <% } %>
      </div>

      <!-- Floating badges -->
      <div class="hero-badge hero-badge-1" aria-hidden="true">
        <strong>100%</strong>
        <span>fait maison</span>
      </div>
      <div class="hero-badge hero-badge-2" aria-hidden="true">
        <strong>🇫🇷</strong>
        <span>viande Limousine</span>
      </div>
    </div>
  </div>

  <!-- Marquee defil ticker -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      <% for (var i = 0; i < 3; i++) { %>
        <span>SMASH BURGERS</span><span class="marquee-dot">●</span>
        <span>TACOS</span><span class="marquee-dot">●</span>
        <span>FRITES DE PANISSES</span><span class="marquee-dot">●</span>
        <span>VIANDE LIMOUSINE</span><span class="marquee-dot">●</span>
        <span>FAIT MAISON</span><span class="marquee-dot">●</span>
        <span>PRODUITS LOCAUX</span><span class="marquee-dot">●</span>
      <% } %>
    </div>
  </div>
</section>

<!-- ─── ABOUT ──────────────────────────────────────────────────────────── -->
<section class="about" id="about">
  <div class="about-inner">
    <div class="about-content reveal">
      <span class="eyebrow"><%= t('about.subtitle') %></span>
      <h2 class="section-title">
        <% var aboutTitle = tr(settings.about_title) || t('about.title'); %>
        <%= aboutTitle %>
      </h2>
      <div class="about-text">
        <% var aboutText = tr(settings.about_text); %>
        <% if (aboutText) { %>
          <%- aboutText.split('\n').filter(function(p) { return p.trim(); }).map(function(p) { return '<p>' + p + '</p>'; }).join('') %>
        <% } else { %>
          <p>Chez Street Food, on aime les bonnes choses. Notre viande est française race Limousine, nos frites sont coupées et dorées maison, nos sauces sont de recette secrète, et même la mousse au chocolat est faite par nos soins.</p>
          <p>Avec une touche provençale qu'on adore — les frites de panisses, à base de farine de pois chiches — on revisite le smash burger avec gourmandise et fraîcheur. Et chaque mois, un nouveau "Daily Street Smash" sort de la cuisine.</p>
        <% } %>
      </div>

      <div class="about-features">
        <div class="about-feature">
          <strong>🇫🇷</strong>
          <span>Viande française<br/>race Limousine</span>
        </div>
        <div class="about-feature">
          <strong>🌿</strong>
          <span>Produits frais<br/>& locaux</span>
        </div>
        <div class="about-feature">
          <strong>👨‍🍳</strong>
          <span>Tout est<br/>fait maison</span>
        </div>
        <div class="about-feature">
          <strong>🌱</strong>
          <span>Options<br/>végétariennes</span>
        </div>
      </div>
    </div>

    <div class="about-visual reveal">
      <% if (settings.about_image) { %>
        <img src="<%= settings.about_image %>" alt="" />
      <% } else if (featured && featured.length > 1 && featured[1].image_path) { %>
        <img src="<%= featured[1].image_path %>" alt="" />
      <% } else { %>
        <div class="about-visual-placeholder">
          <span class="about-visual-emoji">🥖</span>
        </div>
      <% } %>
    </div>
  </div>
</section>

<!-- ─── COUPS DE CŒUR (featured) ───────────────────────────────────────── -->
<% if (featured && featured.length) { %>
<section class="featured">
  <div class="featured-header reveal">
    <span class="eyebrow"><%= t('menu.featured') %></span>
    <h2 class="section-title">Nos incontournables</h2>
  </div>

  <div class="featured-grid">
    <% featured.slice(0, 3).forEach(function(item, idx) { %>
      <article class="featured-card reveal" style="--delay: <%= idx * 0.1 %>s">
        <div class="featured-card-image">
          <% if (item.image_path) { %>
            <img src="<%= item.image_path %>" alt="<%= tr({ fr: item.name_fr, en: item.name_en, it: item.name_it }) %>" loading="lazy" />
          <% } else { %>
            <div class="featured-card-placeholder">🍔</div>
          <% } %>
          <% if (item.is_veggie) { %>
            <span class="badge-veggie" title="<%= t('menu.veggie') %>">🌱 <%= t('menu.veggie') %></span>
          <% } %>
        </div>
        <div class="featured-card-body">
          <h3 class="featured-card-title">
            <%= tr({ fr: item.name_fr, en: item.name_en, it: item.name_it }) %>
          </h3>
          <p class="featured-card-desc">
            <%= tr({ fr: item.description_fr, en: item.description_en, it: item.description_it }) %>
          </p>
          <div class="featured-card-footer">
            <span class="featured-card-price"><%= item.price %></span>
          </div>
        </div>
      </article>
    <% }) %>
  </div>

  <div class="featured-cta reveal">
    <a href="/menu" class="btn btn-outline">
      <span><%= t('hero.cta_menu') %></span>
      <span class="btn-arrow" aria-hidden="true">→</span>
    </a>
  </div>
</section>
<% } %>

<!-- ─── GALERIE PREVIEW ────────────────────────────────────────────────── -->
<% if (gallery && gallery.length) { %>
<section class="gallery-preview">
  <div class="gallery-preview-header reveal">
    <span class="eyebrow"><%= t('gallery.subtitle') %></span>
    <h2 class="section-title"><%= t('gallery.title') %></h2>
  </div>

  <div class="gallery-preview-grid">
    <% gallery.slice(0, 6).forEach(function(photo, idx) { %>
      <a href="/galerie" class="gallery-preview-item reveal" style="--delay: <%= idx * 0.05 %>s">
        <img src="<%= photo.image_path %>" alt="<%= tr({ fr: photo.caption_fr, en: photo.caption_en, it: photo.caption_it }) || '' %>" loading="lazy" />
      </a>
    <% }) %>
  </div>
</section>
<% } %>

<!-- ─── AVIS (preview) ─────────────────────────────────────────────────── -->
<% if (reviews && reviews.length) { %>
<section class="reviews-preview">
  <div class="reviews-preview-inner">
    <div class="reviews-preview-header reveal">
      <span class="eyebrow">★★★★★ <%= settings.rating_value || '4.8' %>/5</span>
      <h2 class="section-title"><%= t('reviews.title') %></h2>
    </div>

    <div class="reviews-preview-grid">
      <% reviews.slice(0, 3).forEach(function(review, idx) { %>
        <article class="review-card reveal" style="--delay: <%= idx * 0.1 %>s">
          <div class="review-card-stars" aria-hidden="true">
            <% for (var i = 0; i < (review.rating || 5); i++) { %>★<% } %>
          </div>
          <p class="review-card-content">
            « <%= tr({ fr: review.content_fr, en: review.content_en, it: review.content_it }) %> »
          </p>
          <div class="review-card-footer">
            <strong><%= review.author %></strong>
            <% if (review.source) { %><span><%= review.source %></span><% } %>
          </div>
        </article>
      <% }) %>
    </div>

    <div class="reviews-preview-cta reveal">
      <a href="/avis" class="btn btn-outline">
        <span><%= t('reviews.see_all') %></span>
        <span class="btn-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
<% } %>

<!-- ─── CONTACT TEASER ─────────────────────────────────────────────────── -->
<section class="contact-teaser">
  <div class="contact-teaser-inner reveal">
    <div class="contact-teaser-content">
      <span class="eyebrow"><%= t('contact.subtitle') %></span>
      <h2 class="section-title"><%= t('contact.title') %></h2>
      <p class="contact-teaser-address">
        <%= settings.address_street || '17 Avenue Gabriel Péri' %><br/>
        <%= settings.address_postal || '30400' %> <%= settings.address_city || 'Villeneuve-lès-Avignon' %>
      </p>
      <div class="contact-teaser-actions">
        <% if (settings.phone) { %>
          <a href="tel:<%= settings.phone.replace(/\s/g, '') %>" class="btn btn-primary">
            <%= t('contact.call') %> · <%= settings.phone %>
          </a>
        <% } %>
        <a href="/contact" class="btn btn-ghost">
          <%= t('nav.contact') %>
          <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <% if (settings.geo_lat && settings.geo_lng) { %>
    <div class="contact-teaser-map">
      <iframe
        src="https://www.google.com/maps?q=<%= settings.geo_lat %>,<%= settings.geo_lng %>&hl=<%= lang %>&z=15&output=embed"
        loading="lazy"
        title="Carte du restaurant"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>
    <% } %>
  </div>
</section>
