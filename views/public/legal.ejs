<section class="page-header">
  <div class="page-header-inner reveal">
    <h1 class="page-title"><em><%= t('footer.legal') %></em></h1>
  </div>
</section>

<section class="legal-page">
  <div class="legal-page-content reveal">
    <h2><%= t('legal.editor') %></h2>
    <p>
      <strong><%= settings.restaurant_name || 'L\'Émulsion' %></strong><br/>
      <%= settings.address_street || '1 rue de l\'Hôpital' %><br/>
      <%= settings.address_postal || '30400' %> <%= settings.address_city || 'Villeneuve-lès-Avignon' %><br/>
      <% if (settings.phone) { %><%= t('contact.phone') %> : <%= settings.phone %><br/><% } %>
      <% if (settings.email) { %>Email : <%= settings.email %><% } %>
    </p>
    <% if (settings.legal_siret) { %>
      <p>SIRET : <%= settings.legal_siret %></p>
    <% } %>

    <h2><%= t('legal.hosting') %></h2>
    <p><%= settings.legal_host || t('legal.hosting_todo') %></p>

    <h2><%= t('legal.ip') %></h2>
    <p><%= t('legal.ip_text') %></p>

    <h2><%= t('legal.data') %></h2>
    <p><%= t('legal.data_text') %></p>

    <h2><%= t('legal.credits') %></h2>
    <p><%= t('legal.credits_text') %></p>
  </div>
</section>
