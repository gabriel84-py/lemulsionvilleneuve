<section class="page-header">
  <div class="page-header-inner reveal">
    <span class="chapter-num">III. Chapitre</span>
    <span class="eyebrow"><%= t('menu.subtitle') %></span>
    <h1 class="page-title"><em><%= t('menu.title') %></em></h1>
    <p class="page-subtitle"><%= t('menu.lede') %></p>
    <div class="ornament" aria-hidden="true"><span class="ornament-diamond"></span></div>
  </div>
</section>

<section class="menu-page">
  <nav class="menu-categories" aria-label="Catégories">
    <% menu.forEach(function(cat) { %>
      <a href="#cat-<%= cat.slug %>" class="menu-category-link" data-cat-link="<%= cat.slug %>">
        <%= tr({ fr: cat.name_fr, en: cat.name_en, it: cat.name_it }) %>
      </a>
    <% }) %>
  </nav>

  <div class="menu-sections">
    <% menu.forEach(function(cat, catIdx) { %>
      <% if (cat.items.length) { %>
        <section class="menu-section" id="cat-<%= cat.slug %>" data-cat="<%= cat.slug %>">
          <header class="menu-section-header reveal">
            <h2 class="menu-section-title">
              <%= tr({ fr: cat.name_fr, en: cat.name_en, it: cat.name_it }) %>
            </h2>
            <% var catDesc = tr({ fr: cat.description_fr, en: cat.description_en, it: cat.description_it }); %>
            <% if (catDesc) { %>
              <p class="menu-section-desc"><%= catDesc %></p>
            <% } %>
          </header>

          <div class="menu-items">
            <% cat.items.forEach(function(item, idx) { %>
              <article class="menu-item reveal" style="--delay: <%= (idx % 4) * 0.06 %>s">
                <% if (item.image_path) { %>
                  <div class="menu-item-image">
                    <img src="<%= item.image_path %>" alt="<%= tr({ fr: item.name_fr, en: item.name_en, it: item.name_it }) %>" loading="lazy" />
                  </div>
                <% } %>
                <div class="menu-item-body">
                  <div class="menu-item-head">
                    <h3 class="menu-item-name">
                      <%= tr({ fr: item.name_fr, en: item.name_en, it: item.name_it }) %>
                      <% if (item.is_featured) { %>
                        <span class="badge-featured" title="<%= t('menu.featured') %>">✦</span>
                      <% } %>
                      <% if (item.is_veggie) { %>
                        <span class="badge-veggie-inline" title="<%= t('menu.veggie') %>"><%= t('menu.veggie') %></span>
                      <% } %>
                    </h3>
                    <span class="menu-item-dots" aria-hidden="true"></span>
                    <span class="menu-item-price"><%= item.price %></span>
                  </div>
                  <% var desc = tr({ fr: item.description_fr, en: item.description_en, it: item.description_it }); %>
                  <% if (desc) { %>
                    <p class="menu-item-desc"><%= desc %></p>
                  <% } %>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      <% } %>
    <% }) %>
  </div>

  <div class="menu-page-cta reveal">
    <% if (settings.phone) { %>
      <a href="tel:<%= settings.phone.replace(/\s/g, '') %>" class="btn-phone">
        <span class="btn-phone-label"><%= t('nav.reserve') %></span>
        <span class="btn-phone-number"><%= settings.phone %></span>
      </a>
    <% } %>
  </div>
</section>
